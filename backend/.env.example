PORT=3001
BACKBLAZE_KEY_ID=your_application_key_id
BACKBLAZE_APPLICATION_KEY=your_application_key
BACKBLAZE_BUCKET_NAME=StudioMaderas
# Optional. If empty, the backend tries landing, Landing, and then bucket root.
BACKBLAZE_FILE_PREFIX=landing
# Optional. Useful when your key cannot list buckets.
BACKBLAZE_BUCKET_ID=
# 1 hour by default. Backblaze allows up to 604800 seconds.
BACKBLAZE_DOWNLOAD_TOKEN_TTL=3600

MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=Studio
LEADS_COLLECTION=landing_clients
